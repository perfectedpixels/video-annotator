# AWS Configuration
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-video-annotation-bucket

# For local development, AWS SDK will use your AWS credentials from:
# - Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# - AWS credentials file (~/.aws/credentials)
# - IAM role (when deployed to EC2/ECS)

# Application Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
# Development: http://localhost:5173
# Production: http://your-server-name.corp.amazon.com or http://your-server-ip:3001
CORS_ORIGIN=http://localhost:5173
